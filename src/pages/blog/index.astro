---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blog';
---

<Layout title="Blog | Naturheilzentrum Sandmann">
	<main class="relative bg-sand-sun min-h-screen pt-48 pb-24">
		<div class="section-container space-y-32">
			<div class="max-w-4xl space-y-12">
				<span class="text-sand-gold font-playfair italic text-3xl">Wissen & Einblicke</span>
				<h1 class="text-7xl md:text-9xl font-playfair text-forest-deep leading-none tracking-tighter">
					Magazin
				</h1>
				<p class="text-xl font-outfit text-forest-deep/60 leading-relaxed">
					Aktuelle Themen aus der Naturheilkunde, Ayurveda und TCM – verständlich erklärt für Ihre Gesundheit im Alltag.
				</p>
			</div>

			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-12">
				{blogPosts.map((post) => (
					<a href={`/blog/${post.slug}`} class="group">
						<article class="space-y-8 cursor-pointer">
							<div class="relative aspect-[16/10] rounded-[2.5rem] overflow-hidden shadow-xl">
								<img 
									src={post.image} 
									alt={post.title} 
									class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
								/>
								<div class="absolute top-6 left-6 px-4 py-2 glass-premium rounded-full text-[10px] tracking-[0.2em] uppercase font-bold text-forest-deep">{post.category}</div>
							</div>
							<div class="space-y-4 px-4 text-left">
								<span class="text-xs uppercase tracking-widest text-sand-gold font-bold">{post.date}</span>
								<h3 class="text-3xl font-playfair text-forest-deep leading-tight group-hover:text-sand-gold transition-colors">
									{post.title}
								</h3>
								<p class="text-forest-deep/60 line-clamp-2">
									{post.excerpt}
								</p>
								<div class="flex items-center gap-2 text-forest-deep font-bold text-xs uppercase tracking-widest pt-4">
									Weiterlesen <div class="w-8 h-px bg-forest-deep"></div>
								</div>
							</div>
						</article>
					</a>
				))}
			</div>
		</div>
	</main>
</Layout>
