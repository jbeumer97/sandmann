---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Behandlungen | Naturheilzentrum Sandmann" description="Entdecken Sie unsere Behandlungskategorien: TCM, Ayurveda und Ästhetik & Wellness.">
	<main class="relative bg-sand-sun min-h-screen pt-48 pb-24">
		<div class="section-container space-y-24">
			<div class="text-center space-y-8">
				<span class="text-sand-gold font-playfair italic text-3xl">Expertise & Heilkunst</span>
				<h1 class="text-7xl md:text-[8rem] font-playfair text-forest-deep leading-none tracking-tighter">
					Behandlungs-<br/>Kategorien
				</h1>
				<p class="max-w-2xl mx-auto text-xl font-outfit text-forest-deep/60">
					Wählen Sie Ihren gewünschten Behandlungsschwerpunkt aus unserem ganzheitlichen Spektrum.
				</p>
			</div>

			<div class="grid md:grid-cols-3 gap-12">
				<a href="/behandlungen/tcm" class="group space-y-6">
					<div class="relative aspect-[4/5] rounded-[3rem] overflow-hidden shadow-xl bg-forest-muted/10">
						<img src="/images/acupuncture.jpg" loading="lazy" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" />
						<div class="absolute inset-0 bg-gradient-to-t from-forest-deep/80 via-forest-deep/30 to-transparent group-hover:via-forest-deep/20 transition-colors"></div>
						<div class="absolute bottom-12 left-8 right-8 text-sand-sun drop-shadow-[0_2px_4px_rgba(78,97,85,0.4)] text-center">
							<h3 class="text-4xl font-playfair font-medium">TCM</h3>
							<span class="text-xs uppercase tracking-[0.3em] font-medium opacity-90 mt-4 block">Naturheilkunde</span>
						</div>
					</div>
				</a>
                <a href="/behandlungen/ayurveda" class="group space-y-6">
					<div class="relative aspect-[4/5] rounded-[3rem] overflow-hidden shadow-xl bg-forest-muted/10">
						<img src="/images/ayurveda_massage.jpg" loading="lazy" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" />
						<div class="absolute inset-0 bg-gradient-to-t from-forest-deep/80 via-forest-deep/30 to-transparent group-hover:via-forest-deep/20 transition-colors"></div>
						<div class="absolute bottom-12 left-8 right-8 text-sand-sun drop-shadow-[0_2px_4px_rgba(78,97,85,0.4)] text-center">
							<h3 class="text-4xl font-playfair font-medium">Ayurveda</h3>
							<span class="text-xs uppercase tracking-[0.3em] font-medium opacity-90 mt-4 block">Tradition</span>
						</div>
					</div>
				</a>
                <a href="/behandlungen/aesthetik-wellness" class="group space-y-6">
					<div class="relative aspect-[4/5] rounded-[3rem] overflow-hidden shadow-xl bg-forest-muted/10">
						<img src="/images/facial_aesthetics.jpg" loading="lazy" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" />
						<div class="absolute inset-0 bg-gradient-to-t from-forest-deep/80 via-forest-deep/30 to-transparent group-hover:via-forest-deep/20 transition-colors"></div>
						<div class="absolute bottom-12 left-8 right-8 text-sand-sun drop-shadow-[0_2px_4px_rgba(78,97,85,0.4)] text-center">
							<h3 class="text-4xl font-playfair font-medium">Ästhetik</h3>
							<span class="text-xs uppercase tracking-[0.3em] font-medium opacity-90 mt-4 block">Wellness</span>
						</div>
					</div>
				</a>
			</div>
		</div>
	</main>
</Layout>
