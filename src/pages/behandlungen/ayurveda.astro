---
import Layout from '../../layouts/Layout.astro';
import { treatments } from '../../data/treatments';

const categoryTreatments = treatments.filter(t => t.category.includes('Ayurveda'));
---

<Layout title="Ayurveda | Naturheilzentrum Sandmann" description="Ganzheitliche Reinigung und Konstitutionslehre nach ayurvedischer Tradition.">
	<main class="relative bg-sand-sun min-h-screen pt-32 md:pt-48 pb-16 md:pb-24">
		<div class="section-container space-y-16 md:space-y-24">
			<div class="text-center space-y-8">
				<span class="text-sand-gold font-playfair italic text-3xl">Ayurveda</span>
				<h1 class="text-7xl md:text-9xl font-playfair text-forest-deep leading-none tracking-tighter">
					Wissen vom <br/>Leben
				</h1>
				<p class="max-w-2xl mx-auto text-xl font-outfit text-forest-deep/60">
					Entdecken Sie die tiefenwirksame Reinigungskraft und die Lehre der ganzheitlichen Dosha-Balance für Ihre Vitalität.
				</p>
			</div>

			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-12">
				{categoryTreatments.map((t) => (
					<a href={`/behandlung/${t.slug}`} class="group space-y-6">
						<div class="relative aspect-[4/5] rounded-[3rem] overflow-hidden shadow-xl bg-forest-muted/10">
							<img 
								src={t.image} 
								alt={t.title} 
								loading="lazy"
								class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
							/>
							<div class="absolute inset-0 bg-gradient-to-t from-forest-deep/80 via-forest-deep/30 to-transparent group-hover:via-forest-deep/20 transition-colors"></div>
							<div class="absolute bottom-6 left-4 right-4 md:bottom-8 md:left-8 md:right-8 text-sand-sun drop-shadow-[0_2px_4px_rgba(78,97,85,0.4)]">
								<span class="text-xs uppercase tracking-[0.3em] font-medium opacity-90">{t.category}</span>
								<h3 class="text-2xl font-playfair font-medium mt-2">{t.title}</h3>
							</div>
						</div>
					</a>
				))}
			</div>
		</div>
	</main>
</Layout>
