---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.tsx';
import TCMSection from '../components/TCMSection.tsx';
import AyurvedaSection from '../components/AyurvedaSection.tsx';
import AestheticSection from '../components/AestheticSection.tsx';
import StatsSection from '../components/StatsSection.tsx';
---

<Layout title="Naturheilzentrum Sandmann | Ayurveda, TCM & Ästhetik Meerbusch">
	<main class="relative bg-warm-ivory overflow-x-hidden">
		<Hero client:load />

		{/* Philosophy Quote Section */}
		<section id="philosophy" class="py-32 lg:py-56 relative overflow-hidden">
			<div className="absolute inset-0 bg-noise pointer-events-none opacity-[0.02]"></div>
			<div class="section-container relative z-10">
				<div class="max-w-5xl mx-auto text-center space-y-12">
					<span class="text-editorial-caption">PHILOSOPHIE</span>
					<h2 class="text-4xl md:text-6xl lg:text-7xl font-serif text-deep-charcoal leading-tight text-balance">
						Gesundheit ist mehr als die Abwesenheit von Krankheit: <br />
						<span class="italic text-stone-taupe">Körper, Geist & Seele im Einklang.</span>
					</h2>
					<div class="w-px h-24 bg-tea-green/30 mx-auto"></div>
					<blockquote class="text-xl md:text-3xl font-serif italic text-deep-charcoal/70 leading-relaxed max-w-4xl mx-auto px-6">
						"Wir betrachten Sie in Ihrer vollkommenen Gesamtheit. Statt lediglich Symptome zu behandeln, ergründen wir die tiefen Ursachen Ihrer Beschwerden, um den Weg zu einem nachhaltigen Wohlbefinden zu ebnen." 
					</blockquote>
					<div class="pt-8">
						<p class="text-[10px] tracking-[0.4em] uppercase text-stone-taupe font-sans">
							Praxis für ganzheitliche Medizin • Meerbusch
						</p>
					</div>
				</div>
			</div>
		</section>

		<TCMSection client:visible />
		<AyurvedaSection client:visible />
		<AestheticSection client:visible />
		<StatsSection client:visible />

		{/* Colon-Hydro-Therapie Featured Section */}
		<section id="detox" class="py-32 lg:py-56 bg-mineral-beige relative overflow-hidden">
			<div class="section-container relative z-10">
				<div class="grid lg:grid-cols-12 gap-16 lg:gap-32 items-center">
					<div class="lg:col-span-7 space-y-12">
						<div class="space-y-6">
							<span class="text-editorial-caption">INNERES GLEICHGEWICHT</span>
							<h2 class="text-5xl md:text-8xl leading-[0.9] text-deep-charcoal">
								Vitalität durch <br /><span class="italic">Darmgesundheit.</span>
							</h2>
						</div>
						<p class="max-w-xl text-lg text-stone-taupe leading-relaxed font-sans font-light">
							Wahres Wohlbefinden entsteht im Zentrum Ihres Körpers. Die ganzheitliche Darmsanierung und Colon-Hydro-Therapie bilden eine wichtige Basis zur Unterstützung eines intakten Immunsystems und neuer Lebensenergie. Durch modernste, absolut hygienische Methoden begleiten wir Sie behutsam zu Ihrer tiefgreifenden Regeneration.
						</p>
						<div class="flex flex-col sm:flex-row gap-6 pt-4">
							<a href="/behandlung/colon-hydro-therapie" class="btn-editorial">
								Mehr über Colon-Hydro
							</a>
							<a href="/behandlung/darmsanierung" class="btn-outline">
								Darmsanierung
							</a>
						</div>
					</div>
					
					<div class="lg:col-span-5 relative">
						<div class="relative aspect-[4/5] overflow-hidden rounded-sm shadow-2xl">
							<img 
								src="/images/detox-ritual.png" 
								alt="Detox Ritual Colon-Hydro" 
								class="w-full h-full object-cover grayscale-[0.1] contrast-[1.05]"
							/>
							<div class="absolute inset-0 bg-tea-green/5 mix-blend-multiply"></div>
						</div>
						<div class="vertical-light-strip left-[-10%] top-[-10%] h-[40%]"></div>
					</div>
				</div>
			</div>
		</section>

		{/* Contact Section */}
		<section id="kontakt" class="py-32 lg:py-56 bg-warm-ivory relative overflow-hidden">
			<div class="section-container">
				<div class="grid lg:grid-cols-12 gap-16 lg:gap-32 items-start">
					
					{/* Left: Contact Info */}
					<div class="lg:col-span-5 space-y-16">
						<div class="space-y-8">
							<span class="text-editorial-caption">KONTAKT</span>
							<h2 class="text-5xl md:text-7xl font-serif text-deep-charcoal leading-tight">
								Lassen Sie uns <br /><span class="italic">beginnen.</span>
							</h2>
							<p class="text-lg text-stone-taupe font-sans font-light leading-relaxed">
								Gerne begleiten wir Sie auf Ihrem individuellen Weg zu mehr Lebensqualität. Kontaktieren Sie uns für ein Erstgespräch oder einen Termin.
							</p>
						</div>

						<div class="space-y-10 group">
							<div class="space-y-2">
								<h4 class="text-[10px] tracking-[0.3em] uppercase text-tea-green font-medium">PRAXIS</h4>
								<p class="text-xl font-serif text-deep-charcoal">Naturheilzentrum Sandmann</p>
								<p class="text-sm text-stone-taupe font-sans">Dimitri & Irina Sandmann • Heilpraktiker</p>
							</div>
							<div class="space-y-2">
								<h4 class="text-[10px] tracking-[0.3em] uppercase text-tea-green font-medium">ADRESSE</h4>
								<p class="text-sm text-stone-taupe font-sans">Standort Meerbusch / Düsseldorf</p>
							</div>
							<div class="space-y-2">
								<h4 class="text-[10px] tracking-[0.3em] uppercase text-tea-green font-medium">DIALOG</h4>
								<p class="text-sm text-stone-taupe font-sans">+49 (0) 2159 8159903</p>
								<p class="text-sm text-stone-taupe font-sans">medizin@naturheilzentrum-sandmann.de</p>
							</div>
						</div>
					</div>

					{/* Right: Contact Form (Consultation Experience) */}
					<div class="lg:col-span-7">
						<div class="surface-limestone p-10 md:p-16 rounded-sm space-y-12">
							<h3 class="text-4xl font-serif text-deep-charcoal italic">Terminanfrage</h3>
							<form id="contact-form" class="space-y-8 transition-opacity duration-1000">
								<div class="grid md:grid-cols-2 gap-8">
									<div class="space-y-2">
										<label class="text-[9px] tracking-[0.2em] uppercase text-stone-taupe">Ihr Name</label>
										<input required type="text" class="w-full bg-transparent border-b border-stone-taupe/30 py-4 focus:border-tea-green outline-none transition-colors font-sans text-sm text-deep-charcoal" />
									</div>
									<div class="space-y-2">
										<label class="text-[9px] tracking-[0.2em] uppercase text-stone-taupe">Ihre E-Mail</label>
										<input required type="email" class="w-full bg-transparent border-b border-stone-taupe/30 py-4 focus:border-tea-green outline-none transition-colors font-sans text-sm text-deep-charcoal" />
									</div>
								</div>
								<div class="space-y-2">
									<label class="text-[9px] tracking-[0.2em] uppercase text-stone-taupe">Worüber möchten Sie sprechen?</label>
									<textarea required rows="4" class="w-full bg-transparent border-b border-stone-taupe/30 py-4 focus:border-tea-green outline-none transition-colors font-sans text-sm text-deep-charcoal resize-none"></textarea>
								</div>
								<button type="submit" class="btn-editorial w-full py-6">
									ANFRAGE SENDEN
								</button>
							</form>
							
							<div id="success-message" class="hidden flex-col items-center justify-center text-center py-10 space-y-6">
								<div class="w-16 h-16 rounded-full border border-tea-green flex items-center justify-center text-tea-green">
									<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
								</div>
								<div class="space-y-2">
									<h4 class="text-3xl font-serif text-deep-charcoal">Herzlichen Dank.</h4>
									<p class="text-sm text-stone-taupe font-sans">Wir haben Ihre Nachricht erhalten und werden uns in Kürze diskret bei Ihnen melden.</p>
								</div>
							</div>
						</div>
					</div>
					
				</div>
			</div>

			<script is:inline>
				const form = document.getElementById('contact-form');
				const successMessage = document.getElementById('success-message');
				if(form && successMessage) {
					form.addEventListener('submit', (e) => {
						e.preventDefault();
						form.classList.add('opacity-0', 'pointer-events-none');
						setTimeout(() => {
							form.classList.add('hidden');
							successMessage.classList.remove('hidden');
							successMessage.classList.add('flex');
						}, 1000);
					});
				}
			</script>
		</section>
	</main>
</Layout>
