---
import Header from '../components/Header.tsx';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	image?: string;
}

const { 
	title, 
	description = "Naturheilzentrum Sandmann - Ganzheitliche Medizin in Meerbusch. Spezialisiert auf TCM, Ayurveda, Colon-Hydro-Therapie und Ästhetik.",
	image = "/og-image.jpg"
} = Astro.props;
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
		<link href="https://api.fontshare.com/v2/css?f[]=satoshi@300,400,500,700&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />
	</head>
	<body>
		<Header client:load />
		<slot />
		<footer class="py-24 bg-mineral-beige border-t border-stone-taupe/20 text-deep-charcoal/40 text-center font-sans text-[10px] tracking-[0.4em] uppercase">
        <div class="section-container space-y-8">
				<div class="font-serif text-2xl text-deep-charcoal/80 normal-case tracking-normal">Sandmann</div>
				<div class="flex flex-wrap justify-center gap-x-8 gap-y-4">
					<a href="/impressum" class="hover:text-tea-green transition-colors">Impressum</a>
					<a href="/datenschutz" class="hover:text-tea-green transition-colors">Datenschutz</a>
					<a href="/kontakt" class="hover:text-tea-green transition-colors">Kontakt</a>
				</div>
				<p>© 2026 Naturheilzentrum Sandmann • Praxis für ganzheitliche Medizin</p>
			</div>
      </footer>
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}
	body {
		overflow-x: hidden;
	}
</style>
